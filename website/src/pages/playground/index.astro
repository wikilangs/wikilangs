          <!-- Axis ticks -->
          ${[1, 10, 100, 500].map(r => `<text x="${xScale(r)}" y="${height - margin.bottom + 20}" text-anchor="middle" font-size="10" fill="var(--color-text-secondary)">${r}</text>`).join('')}

          <!-- Data line -->
