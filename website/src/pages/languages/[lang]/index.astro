---
import BaseLayout from '@layouts/BaseLayout.astro';
import CodeBlock from '@components/CodeBlock.astro';
import { getAllLanguages, getLanguage, getVisualizationUrl, formatNumber, formatCompression } from '@lib/languages';
import type { LanguageData } from '@lib/languages';
import languageCountries from '@data/language_countries.json';
import countryNames from '@data/country_names.json';
import countryToContinentMap from '@data/country_continents.json';

export async function getStaticPaths() {
  const languages = getAllLanguages();
  return languages.map(lang => ({
    params: { lang: lang.code },
    props: { lang }
  }));
}

interface Props {
  lang: LanguageData;
}

const { lang } = Astro.props;
const displayName = lang.common_name || lang.name;
const nativeName = lang.native_name;
const textDirection = lang.text_direction || 'ltr';
const languageWikiUrl = `https://en.wikipedia.org/wiki/${encodeURIComponent(displayName.replace(/ /g, '_'))}_language`;
const wikiSamples = lang.wikipedia_samples || [];

// Countries & continents
const countryLanguages = languageCountries.country_languages || {};
const spokenInCountries: Array<{
  code: string; name: string; isPrimary: boolean;
  wikiEnUrl: string; wikiLangUrl: string | null; continent: string;
}> = [];
const continentsSet = new Set<string>();

for (const [countryCode, data] of Object.entries(countryLanguages)) {
  const allLangs = [...(data.endemic || []), ...(data.macro || [])];
  const langInfo = allLangs.find(l => l.code === lang.code);
  if (langInfo && (countryNames as Record<string, any>)[countryCode]) {
    const country = (countryNames as Record<string, any>)[countryCode];
    const continent = (countryToContinentMap as Record<string, string>)[countryCode] || 'Unknown';
    continentsSet.add(continent);
    spokenInCountries.push({
      code: countryCode, name: country.en, isPrimary: langInfo.primary || false,
      wikiEnUrl: `https://en.wikipedia.org/wiki/${encodeURIComponent(country.en.replace(/ /g, '_'))}`,
      wikiLangUrl: lang.code !== 'en' ? `https://${lang.code}.wikipedia.org/wiki/${encodeURIComponent(country.native || country.en)}` : null,
      continent
    });
  }
}

spokenInCountries.sort((a, b) => {
  if (a.isPrimary !== b.isPrimary) return b.isPrimary ? 1 : -1;
  return a.name.localeCompare(b.name);
});

const continentCount = continentsSet.size;
const countryCount = spokenInCountries.length;
const continentsList = Array.from(continentsSet);

// Visualization URLs
const dashboardUrl = getVisualizationUrl(lang.code, 'performance_dashboard');
const tokenizerUrl = getVisualizationUrl(lang.code, 'tokenizer_compression');
const ngramUrl = getVisualizationUrl(lang.code, 'ngram_perplexity');
const markovUrl = getVisualizationUrl(lang.code, 'markov_entropy');
const zipfUrl = getVisualizationUrl(lang.code, 'zipf_law');
const isotropyUrl = getVisualizationUrl(lang.code, 'embedding_isotropy');
const topWordsUrl = getVisualizationUrl(lang.code, 'top20_words');
---

<BaseLayout
  title={displayName}
  description={`Pre-trained NLP models for ${displayName} (${lang.code}). Tokenizers, n-grams, Markov chains, vocabulary, and embeddings.`}
>
  <!-- ====== HEADER ====== -->
  <section class="lang-header">
    <div class="container">
      <nav class="crumbs">
        <a href="/languages/">Languages</a>
        <span class="crumb-sep">/</span>
        <span>{lang.code}</span>
      </nav>

      <div class="header-row">
        <div class="header-info">
          <span class="code-tag">{lang.code}</span>
          <h1>
            {displayName}
            {nativeName && nativeName !== displayName && (
              <span class="native" dir={textDirection}>{nativeName}</span>
            )}
          </h1>
          <div class="meta-row">
            {lang.alpha_2 && <span class="meta-chip">ISO 639-1: {lang.alpha_2}</span>}
            {lang.alpha_3 && <span class="meta-chip">ISO 639-3: {lang.alpha_3}</span>}
            {lang.scope && <span class="meta-chip">{lang.scope}</span>}
            {lang.language_type && <span class="meta-chip">{lang.language_type}</span>}
          </div>
        </div>
        <div class="header-actions">
          <a href={`/playground/?lang=${lang.code}`} class="btn btn-primary">
            ▶ Playground
          </a>
          <a href={lang.hf_url} class="btn btn-secondary" target="_blank" rel="noopener">HuggingFace</a>
          <a href={languageWikiUrl} class="btn btn-secondary" target="_blank" rel="noopener">Wikipedia</a>
        </div>
      </div>
    </div>
  </section>

  {lang.has_models ? (
    <>
      <!-- Tab nav -->
      <nav class="tab-nav">
        <div class="container">
          <div class="tabs">
            <a href="#overview" class="tab active" data-section="overview">Overview</a>
            <a href="#explore" class="tab" data-section="explore">Explore</a>
            <a href="#technical" class="tab" data-section="technical">Technical</a>
          </div>
        </div>
      </nav>

      <!-- ====== OVERVIEW ====== -->
      <div id="overview" class="page-panel active-panel">

        <!-- Key numbers + minimap -->
        <section class="key-stats">
          <div class="container ks-row">
            <div class="ks-inner">
              <div class="ks-item">
                <span class="ks-val">{formatNumber(lang.vocabulary_size)}</span>
                <span class="ks-lbl">Words in vocabulary</span>
              </div>
              {countryCount > 0 && (
                <div class="ks-item">
                  <span class="ks-val">{countryCount}</span>
                  <span class="ks-lbl">{countryCount === 1 ? 'Country' : 'Countries'}</span>
                </div>
              )}
              {continentCount > 0 && (
                <div class="ks-item">
                  <span class="ks-val">{continentCount}</span>
                  <span class="ks-lbl">{continentCount === 1 ? 'Continent' : 'Continents'}</span>
                </div>
              )}
              {lang.best_compression_ratio && (
                <div class="ks-item">
                  <span class="ks-val">{formatCompression(lang.best_compression_ratio)}</span>
                  <span class="ks-lbl">Best compression</span>
                </div>
              )}
              {lang.best_isotropy && (
                <div class="ks-item">
                  <span class="ks-val">{lang.best_isotropy.toFixed(4)}</span>
                  <span class="ks-lbl">Best isotropy</span>
                </div>
              )}
            </div>
            {continentCount > 0 && (
              <div class="minimap-wrap">
                <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
                <div class="minimap" id="lang-minimap"></div>
                <p class="minimap-caption">{continentsList.join(', ')}</p>
              </div>
            )}
          </div>
        </section>

        <!-- Spoken in -->
        {spokenInCountries.length > 0 && (
          <section class="spoken-section">
            <div class="container">
              <div class="spoken-head">
                <h2>Spoken in</h2>
                <span class="primary-note">* primary</span>
              </div>
              <p class="country-list">
                {spokenInCountries.map((c, i) => (
                  <>
                    <a href={c.wikiEnUrl} target="_blank" rel="noopener" class="country-name">
                      {c.name}{c.isPrimary && <span class="primary-star">*</span>}
                    </a>
                    {c.wikiLangUrl && (
                      <a href={c.wikiLangUrl} target="_blank" rel="noopener" class="country-lang">({lang.code})</a>
                    )}
                    {i < spokenInCountries.length - 1 && <span class="csep">, </span>}
                  </>
                ))}
              </p>
            </div>
          </section>
        )}

        <!-- Samples -->
        {wikiSamples.length > 0 && (
          <section class="section">
            <div class="container">
              <h2>Sample text</h2>
              <p class="section-sub">Excerpts from {displayName} Wikipedia articles.</p>
              <div class="samples" dir={textDirection}>
                {wikiSamples.map(s => (
                  <blockquote class="sample" dir={textDirection}>{s}</blockquote>
                ))}
              </div>
              <div class="sample-actions">
                <a href={`https://${lang.code}.wikipedia.org/`} class="btn btn-sm btn-secondary" target="_blank" rel="noopener">
                  Browse {displayName} Wikipedia
                </a>
                <a href={`/playground/?lang=${lang.code}&demo=weaver`} class="btn btn-sm btn-secondary">
                  Try text generation
                </a>
              </div>
            </div>
          </section>
        )}

        <!-- Top words -->
        <section class="section section-alt">
          <div class="container">
            <h2>Most common words</h2>
            <p class="section-sub">The 20 most frequently used words in {displayName} Wikipedia.</p>
            <div class="viz-frame viz-narrow">
              <img src={topWordsUrl} alt={`Top 20 words in ${displayName}`} loading="lazy" />
            </div>
          </div>
        </section>
      </div>

      <!-- ====== EXPLORE ====== -->
      <div id="explore" class="page-panel">
        <section class="section">
          <div class="container">
            <h2>Interactive playground</h2>
            <p class="section-sub">Explore {displayName} interactively with browser-based demos.</p>
            <div class="demo-grid">
              <a href={`/playground/?lang=${lang.code}&demo=weaver`} class="demo-card">
                <span class="demo-title">Generate Text</span>
                <span class="demo-desc">Markov chains weave words together</span>
              </a>
              <a href={`/playground/?lang=${lang.code}&demo=dna`} class="demo-card">
                <span class="demo-title">Language DNA</span>
                <span class="demo-desc">Character frequencies and word patterns</span>
              </a>
              <a href={`/playground/?lang=${lang.code}&demo=galaxy`} class="demo-card">
                <span class="demo-title">Word Galaxy</span>
                <span class="demo-desc">Words in semantic space</span>
              </a>
              <a href={`/playground/?lang=${lang.code}&demo=zipf`} class="demo-card">
                <span class="demo-title">Zipf's Law</span>
                <span class="demo-desc">Power law of word frequencies</span>
              </a>
              <a href={`/playground/?lang=${lang.code}&demo=museum`} class="demo-card">
                <span class="demo-title">Rare Words</span>
                <span class="demo-desc">Longest and rarest vocabulary</span>
              </a>
              <a href={`/playground/?lang=${lang.code}`} class="demo-card demo-card-all">
                <span class="demo-title">All Demos →</span>
                <span class="demo-desc">Full playground for {displayName}</span>
              </a>
            </div>
          </div>
        </section>
      </div>

      <!-- ====== TECHNICAL ====== -->
      <div id="technical" class="page-panel">

        <!-- Dashboard -->
        <section class="section">
          <div class="container">
            <h2>Performance dashboard</h2>
            <p class="section-sub">Key metrics for all model types at a glance.</p>
            <div class="viz-frame">
              <img src={dashboardUrl} alt={`Performance dashboard for ${displayName}`} loading="lazy" />
            </div>
          </div>
        </section>

        <!-- Quick start code -->
        <section class="section section-alt">
          <div class="container">
            <h2>Quick start</h2>
            <div class="code-grid">
              <div>
                <h3>Tokenizer</h3>
                <CodeBlock code={`from wikilangs import tokenizer\ntok = tokenizer('latest', '${lang.code}', 32000)\ntokens = tok.tokenize("Your text here")`} />
              </div>
              <div>
                <h3>N-gram</h3>
                <CodeBlock code={`from wikilangs import ngram\nng = ngram('latest', '${lang.code}', gram_size=3)\nscore = ng.score("Your text here")`} />
              </div>
              <div>
                <h3>Markov chain</h3>
                <CodeBlock code={`from wikilangs import markov\nmc = markov('latest', '${lang.code}', depth=3)\ntext = mc.generate(length=50)`} />
              </div>
              <div>
                <h3>Vocabulary</h3>
                <CodeBlock code={`from wikilangs import vocabulary\nvocab = vocabulary('latest', '${lang.code}')\ninfo = vocab.lookup("word")`} />
              </div>
              <div>
                <h3>Embeddings</h3>
                <CodeBlock code={`from wikilangs import embeddings\nemb = embeddings('latest', '${lang.code}', dimension=64)\nvec = emb.embed_word("word")`} />
              </div>
            </div>
          </div>
        </section>

        <!-- Available models table -->
        <section class="section">
          <div class="container">
            <h2>Available models</h2>
            <div class="table-frame">
              <table>
                <thead>
                  <tr>
                    <th>Model Type</th>
                    <th>Variants</th>
                    <th>Description</th>
                  </tr>
                </thead>
                <tbody>
                  <tr><td><strong>Tokenizers</strong></td><td>8k, 16k, 32k, 64k</td><td>BPE tokenizers with different vocabulary sizes</td></tr>
                  <tr><td><strong>N-gram (Word)</strong></td><td>2, 3, 4, 5-gram</td><td>Word-level language models</td></tr>
                  <tr><td><strong>N-gram (Subword)</strong></td><td>2, 3, 4, 5-gram</td><td>Subword-level language models</td></tr>
                  <tr><td><strong>Markov (Word)</strong></td><td>Depth 1–5</td><td>Word-level text generation</td></tr>
                  <tr><td><strong>Markov (Subword)</strong></td><td>Depth 1–5</td><td>Subword-level text generation</td></tr>
                  <tr><td><strong>Vocabulary</strong></td><td>—</td><td>Word dictionary with frequency and IDF</td></tr>
                  <tr><td><strong>Embeddings</strong></td><td>32d, 64d, 128d</td><td>Position-aware word embeddings</td></tr>
                </tbody>
              </table>
            </div>
          </div>
        </section>

        <!-- Evaluation tabs -->
        <section class="section section-alt">
          <div class="container">
            <h2>Model evaluation</h2>
            <div class="eval-tabs">
              <button class="eval-tab active" data-tab="tokenizer">Tokenizer</button>
              <button class="eval-tab" data-tab="ngram">N-gram</button>
              <button class="eval-tab" data-tab="markov">Markov</button>
              <button class="eval-tab" data-tab="vocab">Vocabulary</button>
              <button class="eval-tab" data-tab="embeddings">Embeddings</button>
            </div>

            <div class="eval-pane active" id="tab-tokenizer">
              <h3>Tokenizer performance</h3>
              <p>Compression ratios and token statistics across vocabulary sizes.</p>
              <div class="viz-frame"><img src={tokenizerUrl} alt="Tokenizer compression" loading="lazy" /></div>
            </div>
            <div class="eval-pane" id="tab-ngram">
              <h3>N-gram evaluation</h3>
              <p>Perplexity and entropy metrics across n-gram sizes.</p>
              <div class="viz-frame"><img src={ngramUrl} alt="N-gram perplexity" loading="lazy" /></div>
            </div>
            <div class="eval-pane" id="tab-markov">
              <h3>Markov chain evaluation</h3>
              <p>Entropy and branching factor by context depth.</p>
              <div class="viz-frame"><img src={markovUrl} alt="Markov entropy" loading="lazy" /></div>
            </div>
            <div class="eval-pane" id="tab-vocab">
              <h3>Vocabulary analysis</h3>
              <p>Word frequency distribution and Zipf's law analysis.</p>
              <div class="viz-pair">
                <div class="viz-frame"><img src={zipfUrl} alt="Zipf's law" loading="lazy" /></div>
                <div class="viz-frame"><img src={topWordsUrl} alt="Top 20 words" loading="lazy" /></div>
              </div>
            </div>
            <div class="eval-pane" id="tab-embeddings">
              <h3>Embeddings evaluation</h3>
              <p>Isotropy and vector space quality metrics.</p>
              <div class="viz-frame"><img src={isotropyUrl} alt="Embedding isotropy" loading="lazy" /></div>
            </div>
          </div>
        </section>

        <!-- Full report CTA -->
        <section class="section">
          <div class="container" style="text-align:center">
            <h2>Full research report</h2>
            <p class="section-sub" style="max-width:480px;margin-left:auto;margin-right:auto">
              Access the complete ablation study with all metrics, visualizations,
              and generated text samples on HuggingFace.
            </p>
            <a href={lang.hf_url} class="btn btn-primary" target="_blank" rel="noopener">
              View on HuggingFace →
            </a>
          </div>
        </section>
      </div>

      <!-- Scripts -->
      <script>
        // Page section tabs
        const tabs = document.querySelectorAll<HTMLAnchorElement>('.tab');
        const panels = document.querySelectorAll<HTMLElement>('.page-panel');

        function switchPanel(id: string) {
          tabs.forEach(t => t.classList.toggle('active', t.dataset.section === id));
          panels.forEach(p => p.classList.toggle('active-panel', p.id === id));
        }

        tabs.forEach(t => {
          t.addEventListener('click', e => {
            e.preventDefault();
            switchPanel(t.dataset.section || 'overview');
            history.pushState(null, '', `#${t.dataset.section}`);
          });
        });

        switchPanel(window.location.hash.slice(1) || 'overview');

        // Eval tabs
        document.querySelectorAll<HTMLButtonElement>('.eval-tab').forEach(btn => {
          btn.addEventListener('click', () => {
            const id = btn.dataset.tab;
            document.querySelectorAll('.eval-tab').forEach(b => b.classList.toggle('active', b === btn));
            document.querySelectorAll('.eval-pane').forEach(p => p.classList.toggle('active', p.id === `tab-${id}`));
          });
        });
      </script>

      <!-- Minimap -->
      <script is:inline define:vars={{ continentsList }}>
        (function() {
          const mapEl = document.getElementById('lang-minimap');
          if (!mapEl) return;

          const script = document.createElement('script');
          script.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
          script.onload = function() {
            const map = L.map('lang-minimap', {
              center: [20, 0],
              zoom: 1,
              minZoom: 1,
              maxZoom: 1,
              zoomControl: false,
              dragging: false,
              scrollWheelZoom: false,
              doubleClickZoom: false,
              touchZoom: false,
              attributionControl: false,
              keyboard: false
            });

            const style = getComputedStyle(document.documentElement);
            const landColor = style.getPropertyValue('--atlas-map-land').trim() || '#e8e4de';
            const activeColor = style.getPropertyValue('--atlas-map-land-active').trim() || '#3b5998';

            const continentCodes = {
              'Africa': 'AF', 'Asia': 'AS', 'Europe': 'EU',
              'North America': 'NA', 'South America': 'SA', 'Oceania': 'OC'
            };
            const activeSet = new Set(continentsList);
            const base = 'https://raw.githubusercontent.com/rapomon/geojson-places/master/data/continents';

            Object.entries(continentCodes).forEach(function(entry) {
              const name = entry[0];
              const code = entry[1];
              fetch(base + '/' + code + '-simplified.json')
                .then(function(r) { return r.json(); })
                .then(function(geo) {
                  L.geoJSON(geo, {
                    style: function() {
                      return {
                        fillColor: activeSet.has(name) ? activeColor : landColor,
                        fillOpacity: activeSet.has(name) ? 0.65 : 0.3,
                        weight: activeSet.has(name) ? 1 : 0.5,
                        color: activeSet.has(name) ? activeColor : 'rgba(0,0,0,0.08)'
                      };
                    }
                  }).addTo(map);
                }).catch(function(){});
            });
          };
          document.head.appendChild(script);
        })();
      </script>
    </>
  ) : (
    <section class="section" style="text-align:center">
      <div class="container">
        <div style="padding:var(--sp-16) 0">
          <h2>Models coming soon</h2>
          <p style="color:var(--atlas-ink-secondary);margin-bottom:var(--sp-6)">
            Pre-trained models for {displayName} are not yet available. Check back soon.
          </p>
          <a href="/languages/" class="btn btn-secondary">Browse languages</a>
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  /* ====== Header ====== */
  .lang-header {
    padding: var(--sp-8) 0 var(--sp-6);
    background: var(--atlas-surface);
    border-bottom: 1px solid var(--atlas-border);
  }

  .crumbs {
    display: flex;
    gap: var(--sp-2);
    font-size: var(--text-sm);
    color: var(--atlas-ink-muted);
    margin-bottom: var(--sp-4);
  }

  .crumbs a { color: var(--atlas-ink-tertiary); }
  .crumb-sep { color: var(--atlas-ink-muted); }

  .header-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--sp-8);
  }

  .code-tag {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--atlas-accent);
    background: var(--atlas-accent-subtle);
    padding: 3px 10px;
    border-radius: var(--radius-sm);
    margin-bottom: var(--sp-3);
  }

  .header-info h1 {
    font-size: var(--text-4xl);
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: var(--sp-3);
    flex-wrap: wrap;
  }

  .native {
    font-size: var(--text-2xl);
    color: var(--atlas-ink-secondary);
    font-weight: 400;
  }

  .meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    margin-top: var(--sp-4);
  }

  .meta-chip {
    font-size: var(--text-xs);
    color: var(--atlas-ink-tertiary);
    background: var(--atlas-surface-inset);
    padding: 2px 10px;
    border-radius: var(--radius-sm);
  }

  .header-actions {
    display: flex;
    gap: var(--sp-3);
    flex-shrink: 0;
  }

  /* ====== Tab nav ====== */
  .tab-nav {
    background: var(--atlas-surface);
    border-bottom: 1px solid var(--atlas-border);
    position: sticky;
    top: 56px;
    z-index: 20;
  }

  .tabs {
    display: flex;
    gap: 2px;
  }

  .tab {
    padding: var(--sp-3) var(--sp-5);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--atlas-ink-tertiary);
    text-decoration: none;
    border-bottom: 2px solid transparent;
    transition: color var(--duration-fast), border-color var(--duration-fast);
  }

  .tab:hover { color: var(--atlas-ink); text-decoration: none; }
  .tab.active { color: var(--atlas-accent); border-bottom-color: var(--atlas-accent); }

  /* Panels */
  .page-panel { display: none; }
  .page-panel.active-panel { display: block; }

  /* ====== Key stats ====== */
  .key-stats {
    border-bottom: 1px solid var(--atlas-border-subtle);
    padding: var(--sp-6) 0;
  }

  .ks-row {
    display: flex;
    align-items: flex-start;
    gap: var(--sp-8);
  }

  .ks-inner {
    display: flex;
    gap: var(--sp-10);
    flex-wrap: wrap;
    flex: 1;
  }

  .minimap-wrap {
    flex-shrink: 0;
    width: 220px;
  }

  .minimap {
    width: 220px;
    height: 120px;
    border-radius: var(--radius-md);
    border: 1px solid var(--atlas-border);
    overflow: hidden;
    background: var(--atlas-map-water);
  }

  .minimap-caption {
    font-size: var(--text-xs);
    color: var(--atlas-ink-muted);
    margin-top: var(--sp-1);
    text-align: center;
  }

  .ks-item { text-align: center; }

  .ks-val {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-2xl);
    font-weight: 600;
    color: var(--atlas-ink);
    font-variant-numeric: tabular-nums;
  }

  .ks-lbl {
    display: block;
    font-size: var(--text-xs);
    color: var(--atlas-ink-tertiary);
    margin-top: 2px;
  }

  /* ====== Spoken in ====== */
  .spoken-section {
    padding: var(--sp-6) 0;
    background: var(--atlas-surface);
    border-bottom: 1px solid var(--atlas-border-subtle);
  }

  .spoken-head {
    display: flex;
    align-items: center;
