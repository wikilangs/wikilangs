---
import BaseLayout from '@layouts/BaseLayout.astro';
import LanguageCard from '@components/LanguageCard.astro';
import WorldMap from '@components/WorldMap.astro';
import { getAllLanguages, getLanguagesByLetter, getGlobalStats } from '@lib/languages';

const allLanguages = getAllLanguages();
const languagesByLetter = getLanguagesByLetter();
const stats = getGlobalStats();
const sortedLetters = Array.from(languagesByLetter.keys()).sort();
---

<BaseLayout
  title="Languages"
  description={`Browse all ${stats.totalLanguages}+ languages with pre-trained NLP models.`}
>
  <!-- Header -->
  <section class="page-header">
    <div class="container">
      <h1>Languages</h1>
      <p class="page-lead">
        Pre-trained NLP models for {stats.totalLanguages}+ Wikipedia languages.
        Tokenizers, n-gram models, Markov chains, vocabularies, and embeddings.
      </p>
      <div class="header-stats">
        <span class="hs"><strong>{stats.languagesWithModels}</strong> with models</span>
        <span class="hs-dot">·</span>
        <span class="hs"><strong>{stats.averageCompressionRatio.toFixed(2)}x</strong> avg compression</span>
      </div>
    </div>
  </section>

  <!-- Map -->
  <section class="map-area">
    <div class="container">
      <div class="map-intro">
        <h2>Language coverage</h2>
        <p>Explore languages by geographic region. Click a continent to see its languages.</p>
      </div>
      <WorldMap mode="display" height={340} />
    </div>
  </section>

  <!-- Search & Filter — sticky -->
  <section class="filter-bar" id="filter-bar">
    <div class="container filter-inner">
      <div class="search-wrap">
        <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input
          type="search"
          id="language-search"
          placeholder="Search languages…"
          autocomplete="off"
        />
      </div>
      <label class="filter-toggle">
        <input type="checkbox" id="filter-models" checked />
        <span>With models only</span>
      </label>
    </div>

    <div class="container">
      <nav class="alphabet" aria-label="Jump to letter">
        {sortedLetters.map(letter => (
          <a href={`#letter-${letter}`} class="alpha-link">{letter}</a>
        ))}
      </nav>
    </div>
  </section>

  <!-- Language grid by letter -->
  <section class="lang-list">
    <div class="container">
      <div id="languages-container">
        {sortedLetters.map(letter => {
          const langs = languagesByLetter.get(letter) || [];
          return (
            <div class="letter-group" id={`letter-${letter}`}>
              <h2 class="letter-mark">{letter}</h2>
              <div class="lang-grid">
                {langs.map(lang => (
                  <div class="lang-slot" data-code={lang.code} data-name={lang.name.toLowerCase()} data-has-models={lang.has_models}>
                    <LanguageCard lang={lang} />
                  </div>
                ))}
              </div>
            </div>
          );
        })}
      </div>

      <div id="no-results" class="empty-state" hidden>
        <p>No languages found matching your search.</p>
      </div>
    </div>
  </section>

  <script>
    const searchInput = document.getElementById('language-search') as HTMLInputElement;
    const filterModels = document.getElementById('filter-models') as HTMLInputElement;
    const langSlots = document.querySelectorAll('.lang-slot');
    const letterGroups = document.querySelectorAll('.letter-group');
    const noResults = document.getElementById('no-results');

    function filterLanguages() {
      const q = searchInput.value.toLowerCase().trim();
      const modelsOnly = filterModels.checked;
      let visible = 0;

      langSlots.forEach(el => {
        const code = el.getAttribute('data-code') || '';
        const name = el.getAttribute('data-name') || '';
        const hasModels = el.getAttribute('data-has-models') === 'true';
        const show = (!q || code.includes(q) || name.includes(q)) && (!modelsOnly || hasModels);
        (el as HTMLElement).hidden = !show;
        if (show) visible++;
      });

      letterGroups.forEach(g => {
        const any = g.querySelectorAll('.lang-slot:not([hidden])');
        (g as HTMLElement).hidden = any.length === 0;
      });

      if (noResults) noResults.hidden = visible > 0;
    }

    searchInput?.addEventListener('input', filterLanguages);
    filterModels?.addEventListener('change', filterLanguages);
    filterLanguages();
  </script>
</BaseLayout>

<style>
  /* Page header */
  .page-header {
    padding: var(--sp-12) 0 var(--sp-10);
    border-bottom: 1px solid var(--atlas-border);
    background: var(--atlas-surface);
  }

  .page-header h1 {
    margin-bottom: var(--sp-3);
  }

  .page-lead {
    font-size: var(--text-lg);
    color: var(--atlas-ink-secondary);
    max-width: 640px;
    margin-bottom: var(--sp-4);
  }

  .header-stats {
    display: flex;
    gap: var(--sp-3);
    align-items: center;
    font-size: var(--text-sm);
    color: var(--atlas-ink-tertiary);
  }

  .header-stats strong {
    color: var(--atlas-accent);
    font-weight: 600;
    font-family: var(--font-mono);
  }

  .hs-dot {
    color: var(--atlas-ink-muted);
  }

  /* Map */
  .map-area {
    padding: var(--sp-10) 0;
    border-bottom: 1px solid var(--atlas-border-subtle);
  }

  .map-intro {
    margin-bottom: var(--sp-6);
  }

  .map-intro h2 {
    font-size: var(--text-xl);
    margin-bottom: var(--sp-1);
  }

  .map-intro p {
    font-size: var(--text-sm);
    color: var(--atlas-ink-tertiary);
    margin: 0;
  }

  /* Filter bar — sticky */
  .filter-bar {
    position: sticky;
    top: 56px; /* header height */
    z-index: 10;
    background: var(--atlas-bg);
    border-bottom: 1px solid var(--atlas-border);
    padding: var(--sp-4) 0 var(--sp-3);
  }

  .filter-inner {
    display: flex;
    gap: var(--sp-4);
    align-items: center;
    margin-bottom: var(--sp-3);
  }

  .search-wrap {
    position: relative;
    flex: 1;
    max-width: 360px;
  }

  .search-icon {
    position: absolute;
    left: 12px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--atlas-ink-muted);
    pointer-events: none;
  }

  .search-wrap input {
    width: 100%;
    padding: var(--sp-2) var(--sp-4) var(--sp-2) 36px;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    border: 1px solid var(--atlas-border);
    border-radius: var(--radius-md);
    background: var(--atlas-surface);
    color: var(--atlas-ink);
    outline: none;
    transition: border-color var(--duration-fast);
  }

  .search-wrap input:focus {
    border-color: var(--atlas-accent);
    box-shadow: 0 0 0 3px var(--atlas-accent-subtle);
  }

  .filter-toggle {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: var(--text-sm);
    color: var(--atlas-ink-secondary);
    cursor: pointer;
    white-space: nowrap;
  }

  .filter-toggle input {
    accent-color: var(--atlas-accent);
  }

  /* Alphabet */
  .alphabet {
    display: flex;
    flex-wrap: wrap;
    gap: 2px;
  }

  .alpha-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--atlas-ink-tertiary);
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: all var(--duration-fast);
  }

  .alpha-link:hover {
    background: var(--atlas-accent);
    color: #fff;
    text-decoration: none;
  }

  /* Language list */
  .lang-list {
    padding: var(--sp-8) 0 var(--sp-16);
  }

  .letter-group {
    margin-bottom: var(--sp-10);
  }

  .letter-group[hidden] { display: none; }

  .letter-mark {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    color: var(--atlas-ink-tertiary);
    padding-bottom: var(--sp-3);
    border-bottom: 1px solid var(--atlas-border);
    margin-bottom: var(--sp-4);
  }

  .lang-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--sp-4);
  }

  .lang-slot[hidden] { display: none; }

  .empty-state {
    text-align: center;
    padding: var(--sp-16) 0;
    color: var(--atlas-ink-muted);
  }

  .empty-state[hidden] { display: none; }

  @media (max-width: 1024px) {
    .lang-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 768px) {
    .filter-inner { flex-direction: column; align-items: stretch; }
    .search-wrap { max-width: none; }
    .lang-grid { grid-template-columns: repeat(2, 1fr); }
    .alphabet { display: none; }
  }

  @media (max-width: 480px) {
    .lang-grid { grid-template-columns: 1fr; }
  }
</style>
