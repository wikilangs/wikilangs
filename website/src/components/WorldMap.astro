---
/**
 * Interactive World Map using Leaflet — stable layout, no relayouting.
 * Fixed height container prevents layout shifts.
 */

import languageContinents from '@data/language_continents.json';
import languages from '@data/languages.json';

interface Props {
  mode?: 'selector' | 'display';
  height?: number;
}

const { mode = 'display', height = 360 } = Astro.props;

// Build language name lookup
const languageNames: Record<string, string> = {};
for (const lang of languages) {
  languageNames[lang.code] = lang.common_name || lang.name;
}

// Aggregate languages by continent
const continentStats: Record<string, {
  total: number;
  languages: Array<{ code: string; continents: string[] }>;
}> = {};

const allContinents = ['Africa', 'Asia', 'Europe', 'North America', 'South America', 'Oceania'];
for (const continent of allContinents) {
  continentStats[continent] = { total: 0, languages: [] };
}

for (const [langCode, continents] of Object.entries(languageContinents as Record<string, string[]>)) {
  if (!continents || continents.length === 0) continue;
  for (const continent of continents) {
    if (continentStats[continent]) {
      continentStats[continent].languages.push({ code: langCode, continents });
    }
  }
}

for (const continent of allContinents) {
  const stats = continentStats[continent];
  stats.languages.sort((a, b) => {
    const nameA = languageNames[a.code] || a.code;
    const nameB = languageNames[b.code] || b.code;
    return nameA.localeCompare(nameB);
  });
  stats.total = stats.languages.length;
}

let maxLangs = 1;
for (const c in continentStats) {
  if (continentStats[c].total > maxLangs) maxLangs = continentStats[c].total;
}
---

<div class="wm-root" data-mode={mode}>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

  <!-- Fixed-height map container prevents layout shift -->
  <div class="wm-map" id="world-map" style={`height:${height}px`}></div>

  <!-- Info bar with fixed min-height -->
  <div class="wm-info" id="map-info-bar">
    <div class="wm-info-empty" id="info-placeholder">
      <span>Hover over a continent to see languages</span>
    </div>
    <div class="wm-info-active" id="info-active">
      <div class="wm-info-head">
        <span class="wm-continent" id="info-continent"></span>
        <span class="wm-count" id="info-count"></span>
        <div class="wm-filter-wrap" id="filter-wrapper">
          <input type="text" id="lang-filter" placeholder="Filter…" />
        </div>
        <button class="wm-clear" id="info-clear" type="button">✕</button>
      </div>
      <div class="wm-langs" id="info-langs"></div>
    </div>
  </div>
</div>

<style>
  .wm-root {
    position: relative;
    width: 100%;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--atlas-border);
    background: var(--atlas-surface);
  }

  .wm-map {
    width: 100%;
    background: var(--atlas-map-water);
    /* Height is set inline to be stable */
  }

  .wm-info {
    padding: var(--sp-4) var(--sp-5);
    min-height: 80px;
    max-height: 200px;
    border-top: 1px solid var(--atlas-border-subtle);
    background: var(--atlas-surface);
    display: flex;
    flex-direction: column;
  }

  .wm-info-empty {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    font-size: var(--text-sm);
    color: var(--atlas-ink-muted);
  }

  .wm-info-active {
    display: none;
  }

  /* Head row */
  .wm-info-head {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    margin-bottom: var(--sp-3);
  }

  .wm-continent {
    font-weight: 600;
    font-size: var(--text-base);
    color: var(--atlas-ink);
  }

  .wm-count {
    font-size: var(--text-xs);
    color: var(--atlas-ink-tertiary);
    background: var(--atlas-surface-inset);
    padding: 2px 10px;
    border-radius: 100px;
    font-variant-numeric: tabular-nums;
  }

  .wm-clear {
    margin-left: auto;
    background: none;
    border: none;
    font-size: var(--text-sm);
    color: var(--atlas-ink-muted);
    cursor: pointer;
    padding: 4px 8px;
    border-radius: var(--radius-sm);
    display: none;
    line-height: 1;
  }

  .wm-clear:hover {
    color: var(--atlas-error);
    background: rgba(220, 38, 38, 0.06);
  }

  .wm-root.is-locked .wm-clear {
    display: block;
  }

  .wm-filter-wrap {
    display: none;
    margin-left: auto;
  }

  .wm-root.is-locked .wm-filter-wrap {
    display: block;
  }

  #lang-filter {
    padding: 4px 10px;
    font-size: var(--text-xs);
    font-family: var(--font-sans);
    border: 1px solid var(--atlas-border);
    border-radius: var(--radius-md);
    outline: none;
    width: 160px;
    background: var(--atlas-surface-inset);
    color: var(--atlas-ink);
  }

  #lang-filter:focus {
    border-color: var(--atlas-accent);
    box-shadow: 0 0 0 2px var(--atlas-accent-subtle);
  }

  .wm-langs {
    line-height: 1.9;
    display: flex;
    flex-wrap: wrap;
    gap: 4px 12px;
    align-items: baseline;
    overflow-y: auto;
    flex: 1;
    min-height: 0;
  }
</style>

<!-- Global styles for dynamically injected content -->
<style is:global>
  .leaflet-container {
    background: var(--atlas-map-water, #f0eeeb);
    font-family: inherit;
  }

  .wm-root .lang-chip {
    display: inline-flex;
    align-items: baseline;
    white-space: nowrap;
    gap: 2px;
  }

  .wm-root .lang-chip-name {
    color: var(--atlas-ink-secondary, #52525b);
    text-decoration: none;
    border-bottom: 1px dotted var(--atlas-border-subtle, #d1d5db);
    font-size: var(--text-sm, 0.8125rem);
  }

  .wm-root .lang-chip-name:hover {
    color: var(--atlas-accent, #3b5998);
    border-bottom-color: var(--atlas-accent, #3b5998);
  }

  .wm-root .lang-chip-btn {
    background: none;
    border: none;
    padding: 0;
    font: inherit;
    cursor: pointer;
    color: var(--atlas-ink-secondary, #52525b);
    border-bottom: 1px dotted var(--atlas-border-subtle, #d1d5db);
    font-size: var(--text-sm, 0.8125rem);
  }

  .wm-root .lang-chip-btn:hover {
    color: var(--atlas-accent, #3b5998);
    border-bottom-color: var(--atlas-accent, #3b5998);
  }

  .wm-root .lang-chip-count {
    color: var(--atlas-ink-muted, #a1a1aa);
    font-size: 0.7em;
  }

  .wm-root .lang-chip-more {
    color: var(--atlas-ink-muted, #a1a1aa);
    margin-left: 4px;
    font-style: italic;
    font-size: var(--text-sm, 0.8125rem);
  }

  .wm-root .no-results-msg {
    color: var(--atlas-ink-muted, #a1a1aa);
    font-style: italic;
    padding: 8px 0;
    font-size: var(--text-sm, 0.8125rem);
  }
</style>

<script define:vars={{ continentStats, languageNames, mode, maxLangs }}>
  const script = document.createElement('script');
  script.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
  script.onload = initMap;
  document.head.appendChild(script);

  function initMap() {
    const mapEl = document.getElementById('world-map');
    if (!mapEl || typeof L === 'undefined') return;

    const containerWidth = mapEl.offsetWidth;
    const initialZoom = containerWidth < 500 ? 1 : 2;

    const map = L.map('world-map', {
      center: [20, 0],
      zoom: initialZoom,
      minZoom: 1,
      maxZoom: 5,
      worldCopyJump: true,
      attributionControl: false
    });

    // Observe resize without triggering layout shifts
    let resizeRaf = null;
    new ResizeObserver(() => {
      if (resizeRaf) cancelAnimationFrame(resizeRaf);
      resizeRaf = requestAnimationFrame(() => {
        if (mapEl.offsetWidth > 0) map.invalidateSize({ animate: false });
      });
    }).observe(mapEl);

    const wrapper = document.querySelector('.wm-root');
    const placeholder = document.getElementById('info-placeholder');
    const active = document.getElementById('info-active');
    const continentEl = document.getElementById('info-continent');
    const countEl = document.getElementById('info-count');
    const langsEl = document.getElementById('info-langs');
    const clearBtn = document.getElementById('info-clear');
    const filterInput = document.getElementById('lang-filter');

    let locked = null;
    let currentLangs = [];
    let currentIsLocked = false;

    // Accent colors from CSS custom props
    const accentColor = getComputedStyle(document.documentElement).getPropertyValue('--atlas-map-land-active').trim() || '#3b5998';
    const landColor = getComputedStyle(document.documentElement).getPropertyValue('--atlas-map-land').trim() || '#e8e4de';
    const landHoverColor = getComputedStyle(document.documentElement).getPropertyValue('--atlas-map-land-hover').trim() || '#d4cfc6';
    const waterColor = getComputedStyle(document.documentElement).getPropertyValue('--atlas-map-water').trim() || '#f0eeeb';

    function getStyle(continent, hover = false, lock = false) {
      const stats = continentStats[continent];
      if (!stats || stats.total === 0) {
        return { fillColor: waterColor, fillOpacity: 1, weight: 0.5, color: landColor };
      }
      const ratio = stats.total / maxLangs;
      const baseOpacity = 0.4 + ratio * 0.5;

      if (lock) return { fillColor: accentColor, fillOpacity: 0.75, weight: 1.5, color: accentColor };
      if (hover) return { fillColor: landHoverColor, fillOpacity: 0.9, weight: 1, color: accentColor, opacity: 0.5 };
      return { fillColor: landColor, fillOpacity: baseOpacity, weight: 0.5, color: 'rgba(0,0,0,0.1)' };
    }

    function renderLangs(langs, filter = '') {
      const filtered = filter
        ? langs.filter(l => {
            const n = languageNames[l.code] || l.code;
            return n.toLowerCase().includes(filter.toLowerCase()) || l.code.toLowerCase().includes(filter.toLowerCase());
          })
        : langs;

      if (filtered.length === 0) {
        langsEl.innerHTML = '<span class="no-results-msg">No languages match</span>';
        return;
      }

      const displayed = filtered.slice(0, 50);
      const remaining = filtered.length - 50;

      langsEl.innerHTML = displayed.map(l => {
        const n = languageNames[l.code] || l.code;
        const numContinents = l.continents ? l.continents.length : 1;
        const tag = mode === 'display'
          ? `<a href="/languages/${l.code}/" class="lang-chip-name">${n}</a>`
          : currentIsLocked
            ? `<button data-code="${l.code}" class="lang-chip-name lang-chip-btn">${n}</button>`
            : `<span class="lang-chip-name">${n}</span>`;
        const countBadge = numContinents > 1 ? `<span class="lang-chip-count" title="Spoken in ${numContinents} continents">${numContinents}</span>` : '';
        return `<span class="lang-chip">${tag}${countBadge}</span>`;
      }).join('') +
      (remaining > 0 ? `<span class="lang-chip-more">+${remaining} more</span>` : '');

      if (currentIsLocked && mode === 'selector') {
        langsEl.querySelectorAll('button').forEach(btn => {
          btn.onclick = () => {
            wrapper.dispatchEvent(new CustomEvent('languageSelect', {
              bubbles: true,
              detail: { code: btn.dataset.code, name: languageNames[btn.dataset.code] || btn.dataset.code }
            }));
          };
        });
      }
    }

    function showInfo(name, stats, isLocked) {
      currentLangs = stats.languages || [];
      currentIsLocked = isLocked;
      placeholder.style.display = 'none';
      active.style.display = 'block';
      continentEl.textContent = name;
      countEl.textContent = currentLangs.length + ' language' + (currentLangs.length !== 1 ? 's' : '');
      wrapper.classList.toggle('is-locked', isLocked);
      if (filterInput) filterInput.value = '';
      renderLangs(currentLangs);
    }

    function hideInfo() {
      if (locked) return;
      placeholder.style.display = 'flex';
      active.style.display = 'none';
      wrapper.classList.remove('is-locked');
    }

    function clearLock() {
      if (locked) { locked.layer.setStyle(getStyle(locked.continent)); locked = null; }
      placeholder.style.display = 'flex';
      active.style.display = 'none';
      wrapper.classList.remove('is-locked');
    }

    clearBtn?.addEventListener('click', clearLock);
    filterInput?.addEventListener('input', (e) => renderLangs(currentLangs, e.target.value));

    const continentFiles = {
      'AF': 'Africa', 'AS': 'Asia', 'EU': 'Europe',
      'NA': 'North America', 'SA': 'South America', 'OC': 'Oceania'
    };
    const baseUrl = 'https://raw.githubusercontent.com/rapomon/geojson-places/master/data/continents';

    Promise.all(
      Object.entries(continentFiles).map(([code, name]) =>
        fetch(`${baseUrl}/${code}-simplified.json`)
          .then(r => r.json())
          .then(feature => ({ feature, continent: name }))
          .catch(() => null)
      )
    ).then(results => {
      for (const result of results) {
        if (!result) continue;
        const { feature, continent } = result;
        const stats = continentStats[continent];

        const layer = L.geoJSON(feature, { style: () => getStyle(continent) }).addTo(map);

        if (stats?.total > 0) {
          layer.on('mouseover', function() {
            if (locked?.continent !== continent) {
              layer.setStyle(getStyle(continent, true));
              if (!locked) showInfo(continent, stats, false);
            }
          });
          layer.on('mouseout', function() {
            if (locked?.continent !== continent) layer.setStyle(getStyle(continent));
            if (!locked) hideInfo();
          });
          layer.on('click', function(e) {
            L.DomEvent.stopPropagation(e);
            if (locked?.continent === continent) { clearLock(); return; }
            if (locked) locked.layer.setStyle(getStyle(locked.continent));
            layer.setStyle(getStyle(continent, false, true));
            locked = { layer, continent, stats };
            showInfo(continent, stats, true);
          });
        }
      }
      map.on('click', clearLock);
    });
  }
</script>
