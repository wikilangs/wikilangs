---
import type { LanguageData } from '@lib/languages';
import { formatNumber, formatCompression } from '@lib/languages';

interface Props {
  lang: LanguageData;
}

const { lang } = Astro.props;
const displayName = lang.common_name || lang.name;
---

<a href={`/languages/${lang.code}/`} class="lang-card">
  <div class="card-top">
    <span class="code-tag">{lang.code}</span>
    {lang.has_models ? (
      <span class="badge badge-accent">Models</span>
    ) : (
      <span class="badge badge-muted">Soon</span>
    )}
  </div>

  <h3 class="card-name">{displayName}</h3>

  {lang.name !== displayName && (
    <p class="card-alt">{lang.name}</p>
  )}

  {lang.has_models && lang.best_compression_ratio && (
    <div class="card-stat">
      <span class="card-stat-val">{formatCompression(lang.best_compression_ratio)}</span>
      <span class="card-stat-lbl">compression</span>
    </div>
  )}
</a>

<style>
  .lang-card {
    display: flex;
    flex-direction: column;
    background: var(--atlas-surface);
    border: 1px solid var(--atlas-border);
    border-radius: var(--radius-lg);
    padding: var(--sp-4);
    text-decoration: none;
    transition: border-color var(--duration-base) var(--ease-out),
                box-shadow var(--duration-base) var(--ease-out);
    min-height: 120px;
  }

  .lang-card:hover {
    border-color: var(--atlas-border-strong);
    box-shadow: var(--atlas-shadow-md);
    text-decoration: none;
  }

  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--sp-3);
  }

  .code-tag {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--atlas-accent);
    background: var(--atlas-accent-subtle);
    padding: 2px 8px;
    border-radius: var(--radius-sm);
    letter-spacing: 0.02em;
  }

  .card-name {
    font-family: var(--font-serif);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--atlas-ink);
    margin: 0;
    line-height: var(--leading-snug);
  }

  .card-alt {
    font-size: var(--text-xs);
    color: var(--atlas-ink-muted);
    margin: 2px 0 0;
  }

  .card-stat {
    margin-top: auto;
    padding-top: var(--sp-3);
    display: flex;
    align-items: baseline;
    gap: var(--sp-1);
  }

  .card-stat-val {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--atlas-ink);
    font-variant-numeric: tabular-nums;
  }

  .card-stat-lbl {
    font-size: var(--text-xs);
    color: var(--atlas-ink-muted);
  }
</style>
