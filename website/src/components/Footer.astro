---
const currentYear = new Date().getFullYear();

const sections = {
  project: [
    { href: '/languages/', label: 'Languages' },
    { href: '/quickstart/', label: 'Quick Start' },
    { href: '/docs/', label: 'Documentation' },
    { href: '/research/', label: 'Research' },
  ],
  resources: [
    { href: 'https://huggingface.co/wikilangs', label: 'HuggingFace Models', ext: true },
    { href: 'https://huggingface.co/datasets/omarkamali/wikipedia-monthly', label: 'Wikipedia Dataset', ext: true },
    { href: 'https://github.com/omarkamali/babelvec', label: 'BabelVec', ext: true },
    { href: 'https://pypi.org/project/wikilangs/', label: 'PyPI Package', ext: true },
  ],
  about: [
    { href: '/about/', label: 'About' },
    { href: '/cite/', label: 'Citation' },
    { href: '/license/', label: 'License' },
    { href: 'https://github.com/wikilangs/wikilangs', label: 'GitHub', ext: true },
  ],
};
---

<footer class="footer">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <a href="/" class="footer-wordmark">Wikilangs</a>
        <p class="footer-desc">
          Open NLP models for every Wikipedia language.<br />
          Making multilingual NLP accessible to everyone.
        </p>
        <div class="footer-meta">
          <p>
            By <a href="https://omarkamali.com" target="_blank" rel="noopener">Omar Kamali</a>
            at <a href="https://omneitylabs.com" target="_blank" rel="noopener">Omneity Labs</a>
          </p>
          <p>
            Sponsored by <a href="https://featherless.ai" target="_blank" rel="noopener">Featherless.ai</a>
          </p>
        </div>
        <a href="https://doi.org/10.5281/zenodo.18073152" target="_blank" rel="noopener" class="doi-link">
          <img src="https://zenodo.org/badge/DOI/10.5281/zenodo.18073152.svg" alt="DOI" loading="lazy" />
        </a>
      </div>

      <div class="footer-nav">
        <div class="footer-col">
          <h4>Project</h4>
          <ul>
            {sections.project.map(link => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </div>
        <div class="footer-col">
          <h4>Resources</h4>
          <ul>
            {sections.resources.map(link => (
              <li>
                <a href={link.href} target={link.ext ? '_blank' : undefined} rel={link.ext ? 'noopener' : undefined}>
                  {link.label}{link.ext && <span class="ext-arrow"> ↗</span>}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="footer-col">
          <h4>About</h4>
          <ul>
            {sections.about.map(link => (
              <li>
                <a href={link.href} target={link.ext ? '_blank' : undefined} rel={link.ext ? 'noopener' : undefined}>
                  {link.label}{link.ext && <span class="ext-arrow"> ↗</span>}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <span>&copy; {currentYear} Wikilangs · MIT License</span>
      <span>
        Data from <a href="https://wikipedia.org" target="_blank" rel="noopener">Wikipedia</a> under
        <a href="https://creativecommons.org/licenses/by-sa/4.0/" target="_blank" rel="noopener">CC BY-SA 4.0</a>
      </span>
    </div>
  </div>
</footer>

<style>
  .footer {
    margin-top: var(--sp-20);
    border-top: 1px solid var(--atlas-border);
    background: var(--atlas-surface);
    padding: var(--sp-12) 0 var(--sp-8);
  }

  .footer-top {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: var(--sp-16);
  }

  .footer-wordmark {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--atlas-ink);
    text-decoration: none;
  }

  .footer-desc {
    margin-top: var(--sp-3);
    font-size: var(--text-sm);
    color: var(--atlas-ink-secondary);
    line-height: var(--leading-relaxed);
    max-width: 260px;
  }

  .footer-meta {
    margin-top: var(--sp-4);
  }

  .footer-meta p {
    font-size: var(--text-xs);
    color: var(--atlas-ink-tertiary);
    margin-bottom: var(--sp-1);
  }

  .footer-meta a {
    color: var(--atlas-ink-secondary);
    font-weight: 500;
  }

  .doi-link {
    display: inline-block;
    margin-top: var(--sp-4);
  }

  .doi-link img {
    height: 20px;
  }

  /* Nav columns */
  .footer-nav {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-8);
  }

  .footer-col h4 {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--atlas-ink-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: var(--sp-4);
  }

  .footer-col ul {
    list-style: none;
    padding: 0;
  }

  .footer-col li {
    margin-bottom: var(--sp-2);
  }

  .footer-col a {
    font-size: var(--text-sm);
    color: var(--atlas-ink-secondary);
    text-decoration: none;
    transition: color var(--duration-fast);
  }

  .footer-col a:hover {
    color: var(--atlas-accent);
  }

  .ext-arrow {
    font-size: var(--text-xs);
    opacity: 0.5;
  }

  /* Bottom bar */
  .footer-bottom {
    margin-top: var(--sp-10);
    padding-top: var(--sp-6);
    border-top: 1px solid var(--atlas-border-subtle);
    display: flex;
    justify-content: space-between;
    font-size: var(--text-xs);
    color: var(--atlas-ink-muted);
  }

  .footer-bottom a {
    color: var(--atlas-ink-tertiary);
  }

  @media (max-width: 768px) {
    .footer-top {
      grid-template-columns: 1fr;
      gap: var(--sp-10);
    }

    .footer-nav {
      grid-template-columns: repeat(2, 1fr);
    }

    .footer-bottom {
      flex-direction: column;
      gap: var(--sp-2);
    }
  }
</style>
